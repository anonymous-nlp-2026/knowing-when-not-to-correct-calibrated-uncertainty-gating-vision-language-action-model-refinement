"""
CRM training script.

Two-phase approach:
  Phase 1 (--precompute): Run frozen SmolVLA on LIBERO demos, cache
      (obs_features, K_samples, expert_action) to disk.
  Phase 2 (default): Load cached features, train CRM with MSE loss +
      synthetic augmentation.

Usage:
  # Phase 1: precompute features (slow, GPU-heavy)
  python train_crm.py --precompute --benchmark object

  # Phase 2: train CRM (fast)
  python train_crm.py --benchmark object --epochs 50

  # End-to-end (precompute if cache missing, then train)
  python train_crm.py --benchmark object --epochs 50 --auto
"""
import argparse
import os
os.environ.setdefault("HF_HUB_OFFLINE", "1")
os.environ.setdefault("TRANSFORMERS_OFFLINE", "1")
import sys
import json
import time
import signal
import traceback
from pathlib import Path

import torch
import torch.nn as nn
from torch.utils.data import Dataset, DataLoader
import numpy as np

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from cgs import ConformilizedGaussianScoring
from crm import ConformalRefinementModule
from utils import (
    set_seed, load_libero_demos, build_training_samples,
    synthetic_augmentation, CheckpointManager,
    CORRECTION_DIM, H_EFF, OBS_DIM, CHUNK_SIZE,
)


def parse_args():
    p = argparse.ArgumentParser(description="Train CRM on LIBERO demos")
    p.add_argument("--benchmark", type=str, nargs='+', default=["spatial"],
                   choices=["object", "spatial", "goal", "long", "90"])
    p.add_argument("--epochs", type=int, default=50)
    p.add_argument("--batch_size", type=int, default=32)
    p.add_argument("--lr", type=float, default=1e-3)
    p.add_argument("--seed", type=int, default=42)
    p.add_argument("--output_dir", type=str,
                   default="/root/autodl-tmp/checkpoints/crm/")
    p.add_argument("--cache_dir", type=str,
                   default="/root/autodl-tmp/crm_cache/")
    p.add_argument("--K", type=int, default=10)
    p.add_argument("--obs_dim", type=int, default=OBS_DIM)
    p.add_argument("--hidden_dim", type=int, default=256)
    p.add_argument("--aug_noise_min", type=float, default=0.02)
    p.add_argument("--aug_noise_max", type=float, default=0.1)
    p.add_argument("--aug_ratio", type=float, default=0.5,
                   help="fraction of batch to augment")
    p.add_argument("--precompute", action="store_true",
                   help="only precompute features, don't train")
    p.add_argument("--auto", action="store_true",
                   help="precompute if cache missing, then train")
    p.add_argument("--smolvla_path", type=str, default="/root/autodl-tmp/models/smolvla_libero/")
    p.add_argument("--max_demos_per_task", type=int, default=50)
    p.add_argument("--val_split", type=float, default=0.1)
    p.add_argument("--log_every", type=int, default=50)
    p.add_argument("--precompute_batch_size", type=int, default=4,
                   help="batch size for SmolVLA forward during precompute")
    p.add_argument("--save_every", type=int, default=500,
                   help="save partial cache every N samples")
    p.add_argument("--shard_id", type=int, default=0,
                   help="shard ID for parallel precompute (0-based)")
    p.add_argument("--num_shards", type=int, default=1,
                   help="total number of shards for parallel precompute")
    return p.parse_args()


# ── Precomputation ──────────────────────────────────────────────────

def precompute_features(args):
    """Run frozen SmolVLA on all demo timesteps, save features to disk."""
    from smolvla_wrapper import SmolVLAWrapper

    benchmarks_to_run = []
    for bm in args.benchmark:
        cache_dir = Path(args.cache_dir) / bm
        if (cache_dir / "manifest.json").exists():
            print(f"[precompute] Cache exists at {cache_dir}, skipping {bm}.")
        else:
            benchmarks_to_run.append(bm)

    if not benchmarks_to_run:
        return

    print(f"[precompute] Loading SmolVLA from {args.smolvla_path}...")
    wrapper = SmolVLAWrapper(args.smolvla_path, device="cuda")
    print(f"[precompute] VLM hidden_size = {wrapper.vlm_hidden_size}")

    for benchmark_name in benchmarks_to_run:
        cache_dir = Path(args.cache_dir) / benchmark_name
        cache_dir.mkdir(parents=True, exist_ok=True)

        print(f"\n[precompute] Loading {benchmark_name} demos...")
        trajectories = load_libero_demos(benchmark_name,
                                         max_demos_per_task=args.max_demos_per_task)
        samples = build_training_samples(trajectories, h_eff=H_EFF,
                                          action_dim=CORRECTION_DIM)
        print(f"[precompute] {len(samples)} training samples from "
              f"{len(trajectories)} trajectories")

        total = len(samples)
        if args.num_shards > 1:
            shard_size = (total + args.num_shards - 1) // args.num_shards
            start_idx = args.shard_id * shard_size
            end_idx = min(start_idx + shard_size, total)
            samples = samples[start_idx:end_idx]
            print(f"[precompute] Shard {args.shard_id}/{args.num_shards}: "
                  f"samples [{start_idx}:{end_idx}] ({len(samples)} samples)")

        all_obs_features = []
        all_k_samples = []
        all_expert_actions = []
        t0 = time.time()

        for i in range(0, len(samples), args.precompute_batch_size):
            batch = samples[i:i + args.precompute_batch_size]

            obs_feat, k_samp = wrapper.get_obs_features_and_samples_batch(
                batch, K=args.K
            )
            # obs_feat: (B, 960)
            # k_samp: (B, K, chunk_size, FULL_ACTION_DIM) → truncate to (B, K, H_eff, CORRECTION_DIM)
            k_samp_trunc = k_samp[:, :, :H_EFF, :CORRECTION_DIM]

            expert_batch = torch.stack([
                torch.tensor(s["expert_action"], dtype=torch.float32)
                for s in batch
            ])  # (B, H_eff, CORRECTION_DIM)

            all_obs_features.append(obs_feat.cpu())
            all_k_samples.append(k_samp_trunc.cpu())
            all_expert_actions.append(expert_batch)

            if (i + args.precompute_batch_size) % (args.save_every) < args.precompute_batch_size:
                elapsed = time.time() - t0
                done = min(i + args.precompute_batch_size, len(samples))
                rate = done / elapsed if elapsed > 0 else 0
                eta = (len(samples) - done) / rate if rate > 0 else 0
                print(f"  [{done}/{len(samples)}] "
                      f"{rate:.1f} samples/s, ETA {eta:.0f}s")

        obs_features = torch.cat(all_obs_features, dim=0)
        k_samples = torch.cat(all_k_samples, dim=0)
        expert_actions = torch.cat(all_expert_actions, dim=0)

        shard_suffix = f"_shard{args.shard_id}" if args.num_shards > 1 else ""
        torch.save(obs_features, cache_dir / f"obs_features{shard_suffix}.pt")
        torch.save(k_samples, cache_dir / f"k_samples{shard_suffix}.pt")
        torch.save(expert_actions, cache_dir / f"expert_actions{shard_suffix}.pt")

        manifest = {
            "benchmark": benchmark_name,
            "n_samples": len(obs_features),
            "obs_dim": obs_features.shape[1],
            "K": args.K,
            "H_eff": H_EFF,
            "action_dim": CORRECTION_DIM,
            "shard_id": args.shard_id,
            "num_shards": args.num_shards,
        }
        manifest_path = cache_dir / f"manifest{shard_suffix}.json"
        manifest_path.write_text(json.dumps(manifest, indent=2))

        elapsed = time.time() - t0
        print(f"[precompute] {benchmark_name} done: {len(obs_features)} samples "
              f"in {elapsed:.1f}s → {cache_dir}")


# ── Dataset ─────────────────────────────────────────────────────────

class CRMDataset(Dataset):
    """Dataset for CRM training from precomputed features."""

    def __init__(self, obs_features, k_samples, expert_actions):
        self.obs_features = obs_features
        self.k_samples = k_samples
        self.expert_actions = expert_actions

    def __len__(self):
        return len(self.obs_features)

    def __getitem__(self, idx):
        return {
            "obs_features": self.obs_features[idx],
            "k_samples": self.k_samples[idx],
            "expert_action": self.expert_actions[idx],
        }


def load_cached_data(cache_dir: str, benchmarks: list):
    """Load precomputed features from disk, merging multiple benchmarks."""
    all_obs = []
    all_k = []
    all_expert = []

    for bm in benchmarks:
        bm_dir = Path(cache_dir) / bm

        shard_files = sorted(bm_dir.glob("obs_features_shard*.pt"))
        if shard_files:
            for sf in shard_files:
                shard_id = sf.stem.split("shard")[1]
                all_obs.append(torch.load(sf, weights_only=True))
                all_k.append(torch.load(bm_dir / f"k_samples_shard{shard_id}.pt",
                                         weights_only=True))
                all_expert.append(torch.load(bm_dir / f"expert_actions_shard{shard_id}.pt",
                                              weights_only=True))
        else:
            all_obs.append(torch.load(bm_dir / "obs_features.pt", weights_only=True))
            all_k.append(torch.load(bm_dir / "k_samples.pt", weights_only=True))
            all_expert.append(torch.load(bm_dir / "expert_actions.pt", weights_only=True))

    return (torch.cat(all_obs), torch.cat(all_k), torch.cat(all_expert))


# ── Training ────────────────────────────────────────────────────────

def train(args):
    """Train CRM on precomputed features."""
    set_seed(args.seed)
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

    print(f"[train] Loading cached features from {args.cache_dir}...")
    obs_features, k_samples, expert_actions = load_cached_data(
        args.cache_dir, args.benchmark
    )
    print(f"[train] Loaded {len(obs_features)} samples")
    print(f"  obs_features: {obs_features.shape}")
    print(f"  k_samples: {k_samples.shape}")
    print(f"  expert_actions: {expert_actions.shape}")

    n_total = len(obs_features)
    n_val = max(int(n_total * args.val_split), 1)
    n_train = n_total - n_val

    perm = torch.randperm(n_total)
    train_idx = perm[:n_train]
    val_idx = perm[n_train:]

    train_dataset = CRMDataset(
        obs_features[train_idx], k_samples[train_idx], expert_actions[train_idx]
    )
    val_dataset = CRMDataset(
        obs_features[val_idx], k_samples[val_idx], expert_actions[val_idx]
    )

    train_loader = DataLoader(train_dataset, batch_size=args.batch_size,
                               shuffle=True, num_workers=2, pin_memory=True)
    val_loader = DataLoader(val_dataset, batch_size=args.batch_size,
                             shuffle=False, num_workers=2, pin_memory=True)

    cgs = ConformilizedGaussianScoring(K=args.K, horizon=H_EFF, action_dim=CORRECTION_DIM)
    unc_dim = CORRECTION_DIM * H_EFF + H_EFF + H_EFF  # 40

    crm = ConformalRefinementModule(
        action_dim=H_EFF * CORRECTION_DIM,
        uncertainty_dim=unc_dim,
        obs_dim=args.obs_dim,
        hidden_dim=args.hidden_dim,
    ).to(device)

    print(f"[train] CRM: {crm.count_parameters():,} parameters")

    optimizer = torch.optim.AdamW(crm.parameters(), lr=args.lr, weight_decay=1e-4)
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(
        optimizer, T_max=args.epochs, eta_min=1e-6
    )
    loss_fn = nn.MSELoss()

    Path(args.output_dir).mkdir(parents=True, exist_ok=True)
    ckpt_mgr = CheckpointManager(args.output_dir, max_keep=5)

    noise_scale = torch.linspace(
        args.aug_noise_min, args.aug_noise_max, CORRECTION_DIM
    ).to(device)

    best_val_loss = float("inf")

    for epoch in range(1, args.epochs + 1):
        # ── Train ──
        crm.train()
        epoch_loss = 0.0
        n_batches = 0

        for batch_idx, batch in enumerate(train_loader):
            obs_feat = batch["obs_features"].to(device)       # (B, 960)
            k_samp = batch["k_samples"].to(device)             # (B, K, H, D)
            expert = batch["expert_action"].to(device)         # (B, H, D)
            expert_flat = expert.reshape(expert.shape[0], -1)  # (B, 30)

            # CGS
            uf, ma = cgs.compute_features_batch(k_samp)
            uf = uf.to(device)
            ma = ma.to(device)

            # CRM forward
            refined = crm(ma, uf, obs_feat)
            loss = loss_fn(refined, expert_flat)

            # Synthetic augmentation: perturb inputs, keep clean target
            n_aug = int(obs_feat.shape[0] * args.aug_ratio)
            if n_aug > 0:
                ma_noise = noise_scale.repeat(H_EFF)
                aug_ma = ma[:n_aug] + torch.randn_like(ma[:n_aug]) * ma_noise
                aug_uf = uf[:n_aug] + torch.randn_like(uf[:n_aug]) * noise_scale.mean() * 0.1
                aug_refined = crm(aug_ma, aug_uf, obs_feat[:n_aug])
                aug_loss = loss_fn(aug_refined, expert_flat[:n_aug])
                loss = loss + 0.5 * aug_loss

            optimizer.zero_grad()
            loss.backward()
            torch.nn.utils.clip_grad_norm_(crm.parameters(), 1.0)
            optimizer.step()

            epoch_loss += loss.item()
            n_batches += 1

            if (batch_idx + 1) % args.log_every == 0:
                print(f"  epoch {epoch} batch {batch_idx+1}/{len(train_loader)} "
                      f"loss={loss.item():.6f}")

        scheduler.step()
        avg_train_loss = epoch_loss / max(n_batches, 1)

        # ── Validate ──
        crm.eval()
        val_loss = 0.0
        n_val_batches = 0
        with torch.no_grad():
            for batch in val_loader:
                obs_feat = batch["obs_features"].to(device)
                k_samp = batch["k_samples"].to(device)
                expert = batch["expert_action"].to(device)
                expert_flat = expert.reshape(expert.shape[0], -1)

                uf, ma = cgs.compute_features_batch(k_samp)
                uf, ma = uf.to(device), ma.to(device)

                refined = crm(ma, uf, obs_feat)
                val_loss += loss_fn(refined, expert_flat).item()
                n_val_batches += 1

        avg_val_loss = val_loss / max(n_val_batches, 1)

        print(f"Epoch {epoch}/{args.epochs}  "
              f"train_loss={avg_train_loss:.6f}  "
              f"val_loss={avg_val_loss:.6f}  "
              f"lr={scheduler.get_last_lr()[0]:.2e}")

        metrics = {"train_loss": avg_train_loss, "val_loss": avg_val_loss}
        ckpt_mgr.save(crm, optimizer, epoch, metrics)

        if avg_val_loss < best_val_loss:
            best_val_loss = avg_val_loss
            torch.save(crm.state_dict(),
                       Path(args.output_dir) / "crm_best.pt")
            print(f"  → New best val_loss: {best_val_loss:.6f}")

    print(f"\n[train] Done. Best val_loss={best_val_loss:.6f}")
    print(f"[train] Checkpoints at {args.output_dir}")


def main():
    args = parse_args()
    print(f"[train_crm] args: {vars(args)}")
    print(f"[train_crm] device: {'cuda' if torch.cuda.is_available() else 'cpu'}")

    if args.precompute:
        precompute_features(args)
        return

    if args.auto:
        needs_precompute = any(
            not (Path(args.cache_dir) / bm / "manifest.json").exists()
            for bm in args.benchmark
        )
        if needs_precompute:
            print("[auto] Cache not found for some benchmarks, precomputing...")
            precompute_features(args)

    train(args)


if __name__ == "__main__":
    main()
